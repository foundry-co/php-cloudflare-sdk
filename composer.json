{
    "name": "foundry-co/cloudflare",
    "description": "PHP SDK for the Cloudflare API, generated from the official OpenAPI spec",
    "type": "library",
    "license": "MIT",
    "keywords": ["cloudflare", "api", "sdk"],
    "authors": [
        {
            "name": "Foundry",
            "email": "engineering@foundryco.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "cuyz/valinor": "^2.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "nette/php-generator": "^4.0",
        "symfony/console": "^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "FoundryCo\\Cloudflare\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FoundryCo\\Cloudflare\\Generator\\": "generator/src/",
            "FoundryCo\\Cloudflare\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
